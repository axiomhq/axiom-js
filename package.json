{
  "name": "axiom-js-toolkit",
  "private": true,
  "description": "The official JS toolkit & bindings for the Axiom API",
  "version": "0.14.0",
  "author": "Axiom, Inc.",
  "license": "MIT",
  "contributors": [
    "Lukas Malkmus <lukas@axiom.co>",
    "Islam Shehata <islam@axiom.co>",
    "Arne Bahlo <arne@axiom.co>"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axiomhq/axiom-js.git"
  },
  "keywords": [
    "axiom",
    "api",
    "rest",
    "client"
  ],
  "bugs": {
    "url": "https://github.com/axiomhq/axiom-js/issues"
  },
  "homepage": "https://github.com/axiomhq/axiom-js",
  "scripts": {
    "format": "turbo run format",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "build:cjs": "turbo run build:cjs",
    "test": "turbo run test",
    "integration": "turbo run integration",
    "e2e": "turbo run e2e"
  },
  "type": "module",
  "devDependencies": {
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.1",
    "rollup": "^4.60.3",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "turbo": "^2.9.14",
    "typescript": "^5.4.2",
    "vitest": "catalog:",
    "winston": "^3.14.2"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "integration",
    "e2e/*"
  ],
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "overrides": {
      "@babel/runtime@<7.26.10": "7.29.2",
      "ajv@<6.14.0": "6.15.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "8.20.0",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.1.0",
      "diff@>=4.0.0 <4.0.4": "4.0.4",
      "flatted@<=3.4.1": "3.4.2",
      "glob@>=10.2.0 <10.5.0": "10.5.0",
      "js-yaml@>=4.0.0 <4.1.1": "4.1.1",
      "lodash@<=4.17.23": "4.18.1",
      "minimatch@<3.1.4": "3.1.5",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@<8.5.10": "8.5.14",
      "srvx@<0.11.13": "0.11.15",
      "undici@>=7.0.0 <7.24.0": "7.25.0",
      "yaml@>=2.0.0 <2.8.3": "2.8.4"
    }
  }
}
